{
  "$schema": "https://raw.githubusercontent.com/nicehash/tauri/refs/heads/dev/crates/tauri-cli/schema.json",
  "productName": "ZarishNote",
  "version": "0.1.0",
  "identifier": "com.zarishsphere.note",
  "build": {
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "ZarishNote",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "dialog": {},
    "fs": {
      "scope": {
        "allow": ["$APPDATA/**", "$RESOURCE/**", "$HOME/**", "$TEMP/**"],
        "deny": []
      }
    },
    "notification": {
      "all": true
    },
    "clipboard-manager": {
      "all": true
    }
  }
}
