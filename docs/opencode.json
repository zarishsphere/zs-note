{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["AGENTS.md", "README.md", "TODO.md"],
  "skills": {
    "paths": [".opencode/skills"]
  },
  "formatter": false,
  "lsp": false,
  "tool_output": {
    "max_lines": 300
  },
  "permission": {
    "edit": "allow",
    "bash": {
      "git *": "allow",
      "gh *": "allow",
      "rustup *": "allow",
      "cargo *": "allow",
      "pnpm *": "allow",
      "npm *": "allow",
      "node *": "allow",
      "*": "ask"
    },
    "external_directory": {
      "~/.config/opencode/**": "allow",
      "~/.ssh/**": "allow",
      "*": "ask"
    }
  }
}
